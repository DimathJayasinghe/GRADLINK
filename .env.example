# GRADLINK Environment Configuration
# Copy this file to .env and update with your actual values

# Application
APP_NAME="GRADLINK"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/GRADLINK

# Database Configuration
#Main_DB_Vars
DB_HOST=mysql-gradlink-kaveen.alwaysdata.net
DB_PORT=3306
DB_CHARSET=utf8mb4
DB_USER=446251
DB_PASSWORD="#gradlink2025"
DB_NAME=gradlink-kaveen_main

#Local_DB_Vars
# DB_HOST=localhost
# DB_PORT=3306
# DB_CHARSET=utf8mb4
# DB_USER=root
# DB_PASSWORD=1234
# DB_NAME=gl_db

# Email Configuration (for notifications)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@gradlink.com
MAIL_FROM_NAME="${APP_NAME}"

# Session Configuration
SESSION_LIFETIME=120
SESSION_NAME=GRADLINK_SESSION

# Security
SESSION_SECURE=false
SESSION_HTTPONLY=true

# File Upload
UPLOAD_MAX_SIZE=5242880
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif
ALLOWED_DOC_TYPES=pdf,doc,docx

# Fundraiser Settings
FUNDRAISER_MIN_AMOUNT=1000
FUNDRAISER_MAX_AMOUNT=10000000

# Admin Contact
ADMIN_EMAIL=admin@gradlink.com

# Stripe Payment Gateway
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_CURRENCY=LKR
