# GRADLINK Environment Configuration
# Copy this file to .env and update with your actual values

# Application
APP_NAME="GRADLINK"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/GRADLINK

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=gradlink_db

# Email Configuration (for notifications)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@gradlink.com
MAIL_FROM_NAME="${APP_NAME}"
